# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # Supabase Postgres connection string (postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres)

# ── Frontend (exposed to browser via Vite) ──────────────────────
VITE_APP_ID=              # Application ID

# ── Backend (Auth) ─────────────────────────────────────────────
BASE_URL=                 # Base URL for email links (e.g. http://localhost:5173)

# ── Admin Role ──────────────────────────────────────────────────
ADMIN_EMAILS=             # Comma-separated list of emails that get admin role on signup
ADMIN_SECRET_PATH=/admin/login  # Secret admin sign-in URL path

# ── Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=           # Resend API key (optional in dev; logs link if omitted)
FROM_EMAIL=               # Sender address, e.g. noreply@yourdomain.com

# ── Moonshot API ────────────────────────────────────────────────
MOONSHOT_API_KEY=         # Moonshot API key for admin-configured AI features

# ── Stripe (optional — payment integration is mocked by default) ─
STRIPE_PUBLISHABLE_KEY=   # Stripe publishable key (pk_...)
STRIPE_SECRET_KEY=        # Stripe secret key (sk_...)
STRIPE_WEBHOOK_SECRET=    # Stripe webhook endpoint secret (whsec_...)
STRIPE_PRICE_STARTER=     # Stripe Price ID for Starter plan
STRIPE_PRICE_PRO=         # Stripe Price ID for Pro plan
STRIPE_PRICE_PREMIUM=     # Stripe Price ID for Premium plan
